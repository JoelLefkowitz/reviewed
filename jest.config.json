{
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "isolatedModules": true,
        "tsconfig": {
          "sourceMap": true
        }
      }
    ]
  },
  "modulePathIgnorePatterns": ["dist"],
  "setupFilesAfterEnv": ["<rootDir>/src/testing/globals.ts"],
  "collectCoverage": true,
  "coveragePathIgnorePatterns": [
    "<rootDir>/src/internal",
    "<rootDir>/src/testing"
  ]
}
